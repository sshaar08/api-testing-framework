{
  "name": "api-testing-core",
  "version": "1.0.0",
  "description": "Platform-agnostic async/await API integration testing framework for RESTful APIs. Contains core libraries and helper files to facilitate creation of API tests.",
  "author": "Your Name",
  "license": "MIT",
  "repository": "https://github.com/yourusername/api-testing-core",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint --ext .js .",
    "lint:fix": "eslint --ext .js . --fix",
    "test": "mocha --timeout 10000 'test/**/*.test.js'",
    "test:unit": "jest unit-tests",
    "test:all": "npm run test"
  },
  "keywords": [
    "api-testing",
    "integration-testing",
    "rest-api",
    "mocha",
    "chai",
    "async-await"
  ],
  "devDependencies": {
    "dotenv": "^17.0.0",
    "eslint": "^8.57.0",
    "mocha": "^11.0.0",
    "chai": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lodash": "^4.17.21",
    "ramda": "^0.31.0",
    "uuid": "^9.0.0"
  }
}
